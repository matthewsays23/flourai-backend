NODE_ENV=production
PORT=3000
FRONTEND_URL=https://flourai.io
SESSION_SECRET=replace-with-a-long-random-secret
MONGO_URL=mongodb+srv://user:password@cluster/database
MONGO_DB_NAME=flourai

ROBLOX_CLIENT_ID=replace-with-roblox-client-id
ROBLOX_CLIENT_SECRET=replace-with-roblox-client-secret
ROBLOX_REDIRECT_URI=https://api.flourai.io/api/auth/roblox/callback
FLOURAI_GROUP_ID=14811541

DISCORD_CLIENT_ID=replace-with-discord-application-id
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret
DISCORD_REDIRECT_URI=https://api.flourai.io/api/verification/discord/callback
DISCORD_OAUTH_SCOPES=identify guilds.join
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_GUILD_ID=988610987538145330
DISCORD_VERIFIED_ROLE_ID=replace-with-verified-role-id
DISCORD_VERIFY_NICKNAME_FORMAT={robloxUsername}
DISCORD_REMOVE_UNMATCHED_BIND_ROLES=false
DISCORD_ROLE_BINDS=[{"roleId":"customer-discord-role-id","minRank":1},{"roleId":"staff-discord-role-id","minRank":13}]
